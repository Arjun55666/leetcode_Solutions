class Solution {
    public List<Integer> findAnagrams(String s, String p) {
        List<Integer> result = new LinkedList<>();
    
        int[] need = new int[26];//freq array of string p
        for(int i=0;i<p.length();i++){
            need[p.charAt(i)-'a']++;
        }
        int[] window = new int[26];//current  window freq array
        int startIndex=0;
        //traverse s using right pointer
        for(int right=0;right<s.length();right++){
            //add character
            window[s.charAt(right)-'a']++;
            //if windowsize exceeds p length then remove leftmost character
            if(right>=p.length()){
                window[s.charAt(right-p.length())-'a']--;
            }
            //check match 
            if(Arrays.equals(need,window)){
                startIndex=right-p.length()+1;
                result.add(startIndex);
            }
        }
        return result;
        }
}
